# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=3000

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abaco_db
DB_USER=abaco_user
DB_PASSWORD=your_secure_password_here

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=7d

# ===== LEDGER / BLOCKCHAIN INTERNO =====
LEDGER_ENCRYPTION_KEY=your_ledger_encryption_key_min_32_chars

# ===== BLOCKCHAIN EXTERNO (ANCLAJE) =====
BLOCKCHAIN_ENABLED=false
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_NETWORK=localhost
BLOCKCHAIN_PRIVATE_KEY=
BLOCKCHAIN_ANCHOR_CONTRACT=

# ===== AUTO ANCLAJE (SCHEDULER) =====
AUTO_ANCHOR_ENABLED=false
AUTO_ANCHOR_INTERVAL_SECONDS=60
AUTO_ANCHOR_BATCH_LIMIT=10
AUTO_ANCHOR_SOURCE=abaco-auto-scheduler
AUTO_ANCHOR_RETRY_BASE_SECONDS=15
AUTO_ANCHOR_MAX_RETRIES=8

# ===== GOOGLE AUTH =====
# Client ID de Google OAuth (Web Application)
GOOGLE_CLIENT_ID=

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== LOGGING =====
LOG_LEVEL=info

# ===== API DOCS =====
API_TITLE=ÁBACO Backend API
API_VERSION=1.0.0
API_DESCRIPTION=Plataforma electoral territorial profesional

# ===== SECURITY =====
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=15m

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
