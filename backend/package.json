{
  "name": "abaco-backend",
  "version": "1.0.0",
  "description": "Backend profesional para plataforma electoral ÁBACO",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lite:start": "node lite-server.js",
    "lite:dev": "nodemon lite-server.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate-auth-search.js && node scripts/migrate-postgis-sync.js && node scripts/migrate-advanced-security-analytics.js && node scripts/migrate-ledger.js && node scripts/migrate-ledger-anchor.js && node scripts/migrate-ledger-anchor-retry.js",
    "db:migrate:postgis": "node scripts/migrate-postgis-sync.js",
    "db:migrate:advanced": "node scripts/migrate-advanced-security-analytics.js",
    "db:migrate:ledger": "node scripts/migrate-ledger.js",
    "db:migrate:ledger-anchor": "node scripts/migrate-ledger-anchor.js",
    "db:migrate:ledger-retry": "node scripts/migrate-ledger-anchor-retry.js",
    "blockchain:node": "npx hardhat node",
    "blockchain:compile": "npx hardhat compile",
    "blockchain:deploy": "node scripts/blockchain/deploy-ledger-anchor.js",
    "test": "jest --detectOpenHandles",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "electoral",
    "campaña",
    "territorio",
    "gestión"
  ],
  "author": "ÁBACO Team",
  "license": "MIT",
  "dependencies": {
    "@vercel/blob": "^2.3.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "geobuf": "^3.0.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pbf": "^4.0.1",
    "pg": "^8.11.3",
    "shp-write": "^0.3.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "hardhat": "^3.1.11",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
